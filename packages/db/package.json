{
  "name": "@exitstorm/db",
  "version": "0.1.0",
  "description": "SQLite database layer with migrations for ExitStorm",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@exitstorm/core": "workspace:*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "tsx": "^4.6.0",
    "typescript": "^5.6.0"
  }
}
