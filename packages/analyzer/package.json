{
  "name": "@exitstorm/analyzer",
  "version": "0.1.0",
  "description": "AI-powered financial analysis engine for project proposals",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@exitstorm/core": "workspace:*",
    "@exitstorm/team-engine": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "tsx": "^4.6.0",
    "typescript": "^5.6.0"
  }
}
