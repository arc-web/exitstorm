{
  "name": "@exitstorm/api",
  "version": "0.1.0",
  "description": "ExitStorm REST API — projects, leaderboard, and webhooks",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@exitstorm/core": "workspace:*",
    "@exitstorm/analyzer": "workspace:*",
    "@exitstorm/db": "workspace:*",
    "@exitstorm/team-engine": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.6.0"
  }
}
