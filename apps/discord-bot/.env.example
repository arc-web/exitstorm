# Discord Bot Token (required)
BOT_TOKEN=your_discord_bot_token

# AI API Keys (at least one required for /proposeproject analysis)
ANTHROPIC_API_KEY=sk-ant-api-your-key
OPENAI_API_KEY=sk-your-openai-key

